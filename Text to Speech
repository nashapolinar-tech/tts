<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Voice Reader</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: sans-serif;
      background: #fff;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      padding: 24px;
      text-align: center;
    }
    #status {
      font-size: 22px;
      color: #333;
      margin-bottom: 24px;
    }
    #output {
      font-size: 20px;
      color: #111;
      line-height: 1.7;
      max-width: 480px;
      width: 100%;
    }
    #hint {
      position: fixed;
      bottom: 16px;
      font-size: 13px;
      color: #bbb;
    }
  </style>
</head>
<body>

  <div id="status" aria-live="polite">Starting…</div>
  <div id="output" aria-live="polite"></div>
  <p id="hint">Double-tap to close</p>

  <script>
    const status = document.getElementById('status');
    const output = document.getElementById('output');

    const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
    const synth = window.speechSynthesis;

    if (!SR) {
      status.textContent = 'Speech recognition not supported.';
    }

    let recognition;
    let listening = false;
    let finalText = '';

    function speak(text) {
      if (!synth || !text.trim()) return;
      synth.cancel();
      const utt = new SpeechSynthesisUtterance(text);
      utt.lang = 'en-US';
      utt.rate = 1;
      utt.pitch = 1;
      synth.speak(utt);
    }

    function startListening() {
      recognition = new SR();
      recognition.lang = 'en-US';
      recognition.continuous = true;
      recognition.interimResults = true;

      recognition.onstart = () => {
        listening = true;
        status.textContent = 'Listening…';
      };

      recognition.onresult = (e) => {
        let interim = '';
        for (let i = e.resultIndex; i < e.results.length; i++) {
          if (e.results[i].isFinal) {
            const sentence = e.results[i][0].transcript.trim();
            finalText += sentence + ' ';
            output.textContent = finalText;
            speak(sentence);
          } else {
            interim += e.results[i][0].transcript;
          }
        }
        if (interim) output.textContent = finalText + interim;
      };

      recognition.onerror = (e) => {
        if (e.error === 'not-allowed') {
          status.textContent = 'Microphone permission denied.';
        } else {
          setTimeout(() => { if (listening) startListening(); }, 1000);
        }
      };

      recognition.onend = () => {
        if (listening) recognition.start();
      };

      recognition.start();
    }

    function exitApp() {
      if (recognition) recognition.abort();
      synth.cancel();
      status.textContent = 'Closing…';
      try { window.close(); } catch(e) {}
      setTimeout(() => { try { history.go(-999); } catch(e) {} }, 200);
      setTimeout(() => { try { window.location.href = 'about:blank'; } catch(e) {} }, 400);
    }

    // Double-tap anywhere to close
    let tapCount = 0;
    let tapTimer = null;
    document.addEventListener('touchend', () => {
      tapCount++;
      if (tapCount === 1) {
        tapTimer = setTimeout(() => { tapCount = 0; }, 400);
      } else if (tapCount >= 2) {
        clearTimeout(tapTimer);
        tapCount = 0;
        exitApp();
      }
    });

    // Auto-start
    window.addEventListener('load', () => {
      speak('Voice reader ready. Listening now.');
      setTimeout(startListening, 1000);
    });
  </script>
</body>
</html>
